# 100_boxes_input.py
boxes = [0] * 100  # 100 коробок, изначально все пустые

print("Добро пожаловать! Введите число для каждой коробки.")
for i in range(100):
    while True:
        try:
            val = int(input(f"Коробка {i+1}: "))
            boxes[i] = val
            break
        except ValueError:
            print("Пожалуйста, вводите только числа.")

print("Все коробки заполнены!")
print("Содержимое коробок:")
print(boxes)
