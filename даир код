# 100_boxes_guess.py
import random

boxes = [random.randint(1, 100) for _ in range(100)]
print("Коробки заполнены числами от 1 до 100.")

guess = int(input("Попробуй угадать число в одной из коробок (1-100): "))
if guess in boxes:
    index = boxes.index(guess) + 1
    print(f"Угадал! Число {guess} находится в коробке {index}.")
else:
    print(f"Число {guess} нет в коробках.")
