        if self.box_count <= 30:
            cols = 5
        elif self.box_count <= 50:
            cols = 7
        else:
            cols = 10
        
        self.box_buttons = []
        
        for i in range(self.box_count):
            row = i // cols
            col = i % cols
            
            btn = ctk.CTkButton(
                self.boxes_container,
                text=str(i + 1),
                font=("Arial", 14, "bold"),
                fg_color=self.BEIGE,
                hover_color=self.YELLOW,
                text_color=self.DARK_PURPLE,
                width=65,
                height=65,
                corner_radius=12,
                border_width=3,
                border_color=self.ORANGE,
                command=lambda idx=i: self.on_box_click(idx)
            )
            btn.grid(row=row, column=col, padx=4, pady=4)
            self.box_buttons.append(btn)
    
    def start_game(self, mode):
        """Начало игры"""
        self.game_mode = mode
        self.strategy = self.strategy_var.get()
        self.is_running = True
        self.current_prisoner = 1
        self.current_attempts = 0
        self.opened_boxes = []
        self.total_attempts = 0
        
        # Скрываем выбор режима
        self.mode_card.pack_forget()
        
        # Показываем текущий ход
        self.current_card.pack(fill="x", pady=(0, 10))
        self.update_current_info()
        
        if mode == "auto":
            thread = threading.Thread(target=self.run_auto_simulation)
            thread.daemon = True
            thread.start()
    
    def update_current_info(self):
        """Обновление информации о текущем ходе"""
        mode_text = "🎮 Ручной" if self.game_mode == "manual" else "🤖 Авто"
        strategy_text = "🔄 Петлевая" if self.strategy == "loop" else "🎲 Случайная"
        
        info = f"Заключённый: #{self.current_prisoner}\n"
        info += f"Попытки: {self.current_attempts} / {self.max_attempts}\n"
        info += f"Режим: {mode_text}\n"
        info += f"Стратегия: {strategy_text}"
        
        if self.game_mode == "manual" and self.strategy == "loop":
            info += f"\n\n💡 Совет: Начните с #{self.current_prisoner}"
        
        self.current_info.configure(text=info)
    
    def update_stats(self):
        """Обновление статистики"""
        self.stat_remaining.value_label.configure(
            text=str(self.prisoner_count - self.current_prisoner + 1)
        )
        self.stat_successful.value_label.configure(
            text=str(self.successful_prisoners)
        )
        self.stat_failed.value_label.configure(
            text=str(self.failed_prisoners)
        )
        self.stat_attempts.value_label.configure(
            text=str(self.total_attempts)
        )
    
    def on_box_click(self, box_index):
        """Обработка клика на коробку"""
        if not self.is_running or self.game_mode != "manual":
            return
        
        if box_index in self.opened_boxes:
            return
        
        if self.current_attempts >= self.max_attempts:
            return
        
        # Открываем коробку
        self.opened_boxes.append(box_index)
        self.current_attempts += 1
        self.total_attempts += 1
        
        number_in_box = self.boxes[box_index]
        
        # Обновляем кнопку - показываем число внутри и меняем цвет
        self.box_buttons[box_index].configure(
            text=str(number_in_box),
            fg_color=self.PINK,
            border_color=self.YELLOW,
            text_color="white"
        )
        
        self.update_current_info()
        self.update_stats()
        
        # Проверяем результат
        if number_in_box == self.current_prisoner:
            # Успех!
            self.successful_prisoners += 1
            self.root.after(500, self.next_prisoner)
        elif self.current_attempts >= self.max_attempts:
            # Провал
            self.failed_prisoners += 1
            self.root.after(500, self.end_game)
    
    def next_prisoner(self):
        """Переход к следующему заключённому"""
        if self.current_prisoner >= self.prisoner_count:
            # Все прошли!
            self.end_game()
        else:
            # Сброс всех коробок в закрытое состояние (бежевые)
            for i, btn in enumerate(self.box_buttons):
                btn.configure(
                    text=str(i + 1),
                    fg_color=self.BEIGE,
                    text_color=self.DARK_PURPLE,
                    border_color=self.ORANGE
                )
            
            self.current_prisoner += 1
            self.current_attempts = 0
            self.opened_boxes = []
            self.update_current_info()
            self.update_stats()
    
    def run_auto_simulation(self):
        """Автоматическая симуляция"""
        for prisoner in range(1, self.prisoner_count + 1):
            if not self.is_running:
                break
            
            self.current_prisoner = prisoner
            self.current_attempts = 0
            self.opened_boxes = []
            
            self.root.after(0, self.update_current_info)
            
            # Выбор стратегии
            if self.strategy == "loop":
                # Петлевая стратегия
                current_box = prisoner - 1
                found = False
                
                for attempt in range(self.max_attempts):
                    self.opened_boxes.append(current_box)
                    self.current_attempts = attempt + 1
                    self.total_attempts += 1
                    
                    number_in_box = self.boxes[current_box]
                    
                    # Обновляем UI
                    self.root.after(0, lambda idx=current_box, num=number_in_box: 
                        self.box_buttons[idx].configure(
                            text=str(num),
                            fg_color=self.PINK,
                            border_color=self.YELLOW,
                            text_color="white"
                        )
                    )
                    
                    self.root.after(0, self.update_current_info)
                    self.root.after(0, self.update_stats)
                    
                    time.sleep(0.12)
                    
                    if number_in_box == prisoner:
                        found = True
                        break
                    
                    current_box = number_in_box - 1
            else:
                # Случайная стратегия
                available = list(range(self.box_count))
                found = False
                
                for attempt in range(self.max_attempts):
                    box_idx = random.choice(available)
                    available.remove(box_idx)
                    
                    self.opened_boxes.append(box_idx)
                    self.current_attempts = attempt + 1
                    self.total_attempts += 1
                    
                    number_in_box = self.boxes[box_idx]
                    
                    # Обновляем UI
                    self.root.after(0, lambda idx=box_idx, num=number_in_box: 
                        self.box_buttons[idx].configure(
                            text=str(num),
                            fg_color=self.PINK,
                            border_color=self.YELLOW,
                            text_color="white"
                        )
                    )
                    
                    self.root.after(0, self.update_current_info)
                    self.root.after(0, self.update_stats)
                    
                    time.sleep(0.12)
                    
                    if number_in_box == prisoner:
                        found = True
                        break
            
            if found:
                self.successful_prisoners += 1
                self.root.after(0, self.update_stats)
                time.sleep(0.3)
                
                # Сброс коробок для следующего заключённого
                for i, btn in enumerate(self.box_buttons):
                    self.root.after(0, lambda idx=i: 
                        self.box_buttons[idx].configure(
                            text=str(idx + 1),
                            fg_color=self.BEIGE,
                            text_color=self.DARK_PURPLE,
                            border_color=self.ORANGE
                        )
                    )
            else:
                self.failed_prisoners += 1
                self.root.after(0, self.update_stats)
                self.root.after(0, self.end_game)
                break
        
        if self.is_running:
            self.root.after(0, self.end_game)
    
    def end_game(self):
        """Завершение игры"""
        self.is_running = False
        
        # Скрываем текущий ход
        self.current_card.pack_forget()
        
        # Показываем результат
        if self.failed_prisoners == 0:
            self.result_card.configure(
                fg_color=self.GREEN,
                border_width=4,
                border_color=self.YELLOW
            )
            emoji = "🎉"
            title = "ВСЕ ВЫЖИЛИ!"
        else:
            self.result_card.configure(
                fg_color=self.ORANGE,
                border_width=4,
                border_color=self.PINK
            )
            emoji = "💀"
            title = "ПРОВАЛ!"
        
        # Очищаем карточку результата
        for widget in self.result_card.winfo_children():
            widget.destroy()
        
        emoji_label = ctk.CTkLabel(
            self.result_card,
            text=emoji,
            font=("Arial", 60)
        )
        emoji_label.pack(pady=(25, 10))
        
        title_label = ctk.CTkLabel(
            self.result_card,
            text=title,
            font=("Arial", 28, "bold"),
            text_color="white"
        )
        title_label.pack(pady=10)
        
        result_text = ctk.CTkLabel(
            self.result_card,
            text=f"✅ {self.successful_prisoners} из {self.prisoner_count}\n"
                 f"заключённых нашли свои номера\n\n"
                 f"🎯 Всего попыток: {self.total_attempts}",
            font=("Arial", 16, "bold"),
            text_color="white"
        )
        result_text.pack(pady=10)
        
        # Кнопка "Начать заново"
        play_again_button = ctk.CTkButton(
            self.result_card,
            text="🔄 Начать заново",
            font=("Arial", 18, "bold"),
            fg_color="white",
            hover_color=self.YELLOW,
            text_color=self.DARK_PURPLE,
            height=60,
            corner_radius=15,
            command=self.reset_game
        )
        play_again_button.pack(pady=(15, 25), padx=20, fill="x")
        
        self.result_card.pack(fill="x", pady=(0, 10))
    
    def reset_game(self):
        """Сброс игры"""
        self.result_card.pack_forget()
        self.mode_card.pack(fill="x", pady=(0, 10))
        
        self.initialize_boxes()
        
        # Сброс всех коробок
        for i, btn in enumerate(self.box_buttons):
            btn.configure(
                text=str(i + 1),
                fg_color=self.BEIGE,
                text_color=self.DARK_PURPLE,
                border_color=self.ORANGE
            )
        
        self.update_stats()

if __name__ == "__main__":
    app = PrisonersGame()
