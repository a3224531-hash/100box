    def run_1000_simulation(self, strategy):
        """Запуск симуляции 1000 игр"""
        self.sim_start_button.configure(state="disabled")
        
        def simulate():
            wins = 0
            total_games = 1000
            
            for game in range(total_games):
                # Обновление прогресса
                progress = (game + 1) / total_games
                self.root.after(0, lambda p=progress: self.sim_progress.set(p))
                
                # Симуляция одной игры
                boxes = list(range(1, self.box_count + 1))
                random.shuffle(boxes)
                
                all_found = True
                for prisoner in range(1, self.prisoner_count + 1):
                    found = False
                    max_attempts = self.box_count // 2
                    
                    if strategy == "loop":
                        # Петлевая стратегия
                        current_box = prisoner - 1
                        for _ in range(max_attempts):
                            if boxes[current_box] == prisoner:
                                found = True
                                break
                            current_box = boxes[current_box] - 1
                    else:
                        # Случайная стратегия
                        available = list(range(self.box_count))
                        for _ in range(max_attempts):
                            box_idx = random.choice(available)
                            available.remove(box_idx)
                            if boxes[box_idx] == prisoner:
                                found = True
                                break
                    
                    if not found:
                        all_found = False
                        break
                
                if all_found:
                    wins += 1
                
                # Обновление результатов
                current_percent = (wins / (game + 1)) * 100
                result_text = f"🎮 Игр сыграно: {game + 1} / {total_games}\n"
                result_text += f"✅ Побед: {wins}\n"
                result_text += f"❌ Поражений: {game + 1 - wins}\n"
                result_text += f"📊 Процент побед: {current_percent:.2f}%"
                
                self.root.after(0, lambda t=result_text: self.sim_result_label.configure(text=t))
            
            self.root.after(0, lambda: self.sim_start_button.configure(state="normal"))
        
        thread = threading.Thread(target=simulate)
        thread.daemon = True
        thread.start()
    
