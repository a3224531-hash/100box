    def validate_and_start(self):
        """Валидация ввода и начало игры"""
        try:
            prisoners = int(self.prisoner_entry.get())
            boxes = int(self.box_entry.get())
            
            if not (10 <= prisoners <= 100):
                self.show_error("Количество заключённых должно быть от 10 до 100!")
                return
            
            if not (10 <= boxes <= 100):
                self.show_error("Количество коробок должно быть от 10 до 100!")
                return
            
            self.prisoner_count = prisoners
            self.box_count = boxes
            self.show_game_screen()
            
        except ValueError:
            self.show_error("Пожалуйста, введите корректные числа!")
    
